{
  "name": "candidate-stock-assist",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "update": "node scripts/update-data.mjs",
    "report": "node scripts/generate-morning-report.mjs",
    "morning": "node scripts/morning-update.mjs",
